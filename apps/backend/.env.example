# ── Contabilidad Morsa — Variables de entorno del backend ─────────────────────
# Copia este archivo como .env y completa los valores.
# En Render, configura estas variables desde el panel de Environment.

# ── Base de datos ─────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection String → Transaction Pooler
# Formato: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── CORS: dominio del frontend desplegado en Vercel ───────────────────────────
# Separa múltiples dominios con coma. Sin barra final.
# Ejemplo: https://contabilidad-morsa.vercel.app,https://contabilidad.midominio.com
MORSA_ALLOWED_ORIGINS=https://tu-app.vercel.app

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Secreto interno para endurecer tokens y sesiones (genera uno aleatorio largo).
MORSA_API_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# "Pepper" opcional para endurecer el hash de contraseñas.
MORSA_PASSWORD_PEPPER=

# Duración máxima de la sesión en horas.
MORSA_SESSION_HOURS=12

# Usuario administrador inicial automático.
# Déjalo vacío si prefieres crear el primer administrador desde la pantalla de login.
MORSA_ADMIN_USERNAME=
MORSA_ADMIN_PASSWORD=
MORSA_ADMIN_FULL_NAME=Administrador General

# ── Swagger / Redoc ───────────────────────────────────────────────────────────
# Pon "1" solo en desarrollo. En producción debe ser "0".
MORSA_ENABLE_DOCS=0

# ── Logging ───────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
